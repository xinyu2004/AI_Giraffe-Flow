package oem_a.demo

// Sample SOME/IP deployment for parse_fdepl (P1 B staged — not req.bindings).
define oem_a.demo.VehicleStatus someip {
  SomeIpServiceID = 0x1234
  SomeIpInstanceID = 1

  method getPose {
    SomeIpMethodID = 0x0001
  }

  broadcast SpeedChanged {
    SomeIpEventID = 0x8001
  }
}
